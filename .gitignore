# --- Окружение и зависимости ---
# Игнорируем папки виртуальных сред. В них установлены библиотеки. 
# Git должен хранить только список библиотек в pyproject.toml, а не сами библиотеки.
.venv/
venv/
ENV/
env/
# Папка с метаданными Poetry, не нужна в репозитории.
.poetry/
poetry.toml
# Папки для собранных дистрибутивов проекта, нам не нужно версионировать сборки.
dist/
build/

# --- Кэш Python и инструментов качества ---
# Скомпилированные файлы Python. Они пересоздаются при каждом запуске.
__pycache__/
*.pyc
*.pyo
*.pyd
# Временные файлы кэша тестов (pytest), линтера (ruff) и системы типов (mypy).
# Помогают инструментам работать быстрее, но не несут ценности для кода.
.pytest_cache/
.ruff_cache/
.mypy_cache/

# --- Автоматизация (Copier) ---
# Файл с ответами на вопросы шаблонизатора. Обычно содержит пути вашего ПК, 
# поэтому его нельзя "шарить" с другими.
.copier-answers.yml

# --- Логи и базы данных ---
# Логи могут быть огромными и содержать технические подробности.
# Не засоряем репозиторий данными о работе программы.
*.log
logs/
# Файлы локальных БД. Они меняются при каждом запуске, Git будет постоянно 
# "ругаться" на конфликты версий в базе.
*.sqlite

# --- Файлы данных и фикстуры ---
# Игнорируем рабочие файлы данных. Это предотвращает случайную загрузку 
# конфиденциальных данных биржи в публичный репозиторий.
*.csv
*.xlsx
# Тяжелый JSON, который нужен для тестов, но его не нужно хранить в истории Git.
data/fixtures/securities_real.json

# --- Настройки IDE (VS Code / PyCharm) ---
# Настройки редакторов. Они уникальны для каждого разработчика (монитор, шрифты, темы).
.vscode/
.idea/
# Системные файлы настроек Windows/Visual Studio.
*.suo
*.ntvs*
*.njsproj
*.sln
# Временные файлы редакторы, которые создаются при открытии файла.
*.swp

# --- Системные файлы ---
# Файлы ОС macOS и Windows, создаваемые при просмотре папок. Не несут никакой пользы.
.DS_Store
Thumbs.db